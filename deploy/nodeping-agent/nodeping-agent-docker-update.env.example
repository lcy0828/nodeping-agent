# Optional systemd timer environment for Docker-based agent deployments.
# Default compose file is /opt/nodeping-agent/compose.yml. Leave COMPOSE_FILE empty
# to let docker compose use its standard file name automatically.
COMPOSE_FILE=
ENV_FILE=/opt/nodeping-agent/.env
PROJECT_DIRECTORY=/opt/nodeping-agent
SERVICE=nodeping-agent

# Pull published images by default. Set to 1 for source-tree hosts that should rebuild.
NODEPING_AGENT_DOCKER_BUILD=0
