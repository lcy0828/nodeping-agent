# Static release base URL. It must contain latest.txt, checksums, and tar.gz files
# generated by scripts/build-nodeping-agent.sh.
NODEPING_AGENT_RELEASE_BASE_URL=https://downloads.example.com/nodeping-agent

# Use latest or an exact version string.
NODEPING_AGENT_VERSION=latest

NODEPING_AGENT_INSTALL_PATH=/opt/nodeping-agent/nodeping-agent
NODEPING_AGENT_SERVICE=nodeping-agent.service
NODEPING_AGENT_RESTART=1

# Rollback keeps the previous binary here and restores it when systemd restart fails.
NODEPING_AGENT_BACKUP_PATH=/opt/nodeping-agent/nodeping-agent.previous
NODEPING_AGENT_START_TIMEOUT_SECONDS=20

# Minisign verification is required automatically when a public key is configured.
# Leave the key empty to use SHA256 only.
NODEPING_AGENT_MINISIGN_PUBLIC_KEY=
NODEPING_AGENT_REQUIRE_SIGNATURE=auto
