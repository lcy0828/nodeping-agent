NODEPING_SERVER_URL=https://your-nodeping.example
# Development only: set true when NODEPING_SERVER_URL is a non-loopback HTTP URL.
NODEPING_AGENT_ALLOW_INSECURE_HTTP=false
NODEPING_TOKEN=np_xxx
# Leave empty to let the agent generate and persist a stable ID in the host data directory.
NODEPING_AGENT_ID=
NODEPING_AGENT_NAME=NodePing Docker Agent
# cn prefers HubProxy and falls back to GHCR; global uses the reverse order.
NODEPING_AGENT_DISTRIBUTION_MODE=cn
NODEPING_AGENT_DOCKER_IMAGE_CN=hub.ilatency.com/ghcr.io/lcy0828/nodeping-agent
NODEPING_AGENT_DOCKER_IMAGE_GLOBAL=ghcr.io/lcy0828/nodeping-agent
NODEPING_AGENT_IMAGE=hub.ilatency.com/ghcr.io/lcy0828/nodeping-agent
NODEPING_AGENT_IMAGE_VERSION=latest
NODEPING_AGENT_DEPLOY_BASE_URL=https://hub.ilatency.com/https://raw.githubusercontent.com/lcy0828/nodeping-agent/main/deploy/nodeping-agent
# Keep identity and token state in a stable host directory across reinstalls.
NODEPING_AGENT_DOCKER_DATA_DIRECTORY=/opt/nodeping-agent/data
# Persist the self-updated executable separately from identity and token state.
NODEPING_AGENT_DOCKER_RUNTIME_DIRECTORY=/opt/nodeping-agent/runtime
# Keep the default Compose synchronized during image updates. Custom Compose
# paths are never overwritten.
NODEPING_AGENT_DOCKER_SYNC_DEPLOYMENT=1
NODEPING_AGENT_IMAGE_COMMIT=unknown
NODEPING_AGENT_IMAGE_BUILD_DATE=unknown
NODEPING_HEARTBEAT_INTERVAL=20s
NODEPING_PUBLIC_IP_INTERVAL=10m
NODEPING_CONCURRENCY=10
NODEPING_SHUTDOWN_DRAIN_TIMEOUT=15s
# Docker upgrades the Agent binary inside the container; no host init watcher or
# Docker Socket is required. Base-image refreshes remain a manual maintenance task.
NODEPING_AGENT_UPGRADE_MODE=container
NODEPING_AGENT_ACTIVATION_STABLE_SECONDS=20
NODEPING_AGENT_MINISIGN_PUBLIC_KEY=
NODEPING_AGENT_REQUIRE_SIGNATURE=auto
NODEPING_AGENT_SIGNATURE_REQUIRED_FROM=
NODEPING_AGENT_STOP_GRACE_PERIOD=35s
NODEPING_AGENT_LOG_MAX_SIZE=10m
NODEPING_AGENT_LOG_MAX_FILES=3
