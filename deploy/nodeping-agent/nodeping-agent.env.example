# Required. Public backend base URL reachable from this agent.
NODEPING_SERVER_URL=https://your-nodeping.example

# Required for first bind/register. Keep it secret.
NODEPING_TOKEN=np_xxx

# Stable identity shown in NodePing. Use one id per machine/container.
NODEPING_AGENT_ID=agent-example-1
NODEPING_AGENT_NAME=NodePing Agent Example
NODEPING_AGENT_DISTRIBUTION_MODE=cn

# The backend returns a long-lived agent token after registration.
# Keep this file on persistent storage.
NODEPING_AGENT_TOKEN_FILE=/var/lib/nodeping-agent/agent-token
NODEPING_AGENT_RELEASE_PROXY_FILE=/var/lib/nodeping-agent/release-proxies.tsv
NODEPING_AGENT_LATEST_VERSION_FILE=/var/lib/nodeping-agent/latest-version

NODEPING_HEARTBEAT_INTERVAL=20s
NODEPING_PUBLIC_IP_INTERVAL=10m
NODEPING_CONCURRENCY=10
NODEPING_SHUTDOWN_DRAIN_TIMEOUT=15s

# Remote control uses a fixed allowlist. In systemd installs the agent writes
# this request file and nodeping-agent-update.path starts the root update unit.
NODEPING_AGENT_UPGRADE_MODE=request_file
NODEPING_AGENT_UPGRADE_REQUEST_FILE=/var/lib/nodeping-agent/update-request.json
