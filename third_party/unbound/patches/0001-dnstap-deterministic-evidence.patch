 	}
 #endif
 	return 1;
@@ -2595,7 +2596,7 @@ struct waiting_tcp* pending_tcp_query(struct serviced_query* sq,
 			sldns_buffer_init_frm_data(&tmp, w->pkt, w->pkt_len);
 			dt_msg_send_outside_query(sq->outnet->dtenv, &sq->addr,
 				&pend->pi->addr, comm_tcp, NULL, sq->zone,
-				sq->zonelen, &tmp);
+				sq->zonelen, &tmp, &sq->last_sent_time);
 		}
 #endif
 	} else {
